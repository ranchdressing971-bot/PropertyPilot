# OpenAI (required for Live mode — server-side only, no NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (required for sign-in + data persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Your live site URL (YOU set this — not found in Stripe/Supabase)
# Vercel: Project → Settings → Domains, e.g. https://property-pilot.vercel.app
# Or your custom domain. No trailing slash.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Stripe — Product ID is prod_... but checkout needs the PRICE ID (price_...)
# Stripe Dashboard → Products → your $149 product → Pricing → copy price_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Optional reference only (not used at checkout):
# STRIPE_PRODUCT_ID=prod_UnRLrryaB03Nan

# Resend (violation emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Property Pilot <notifications@yourdomain.com>
