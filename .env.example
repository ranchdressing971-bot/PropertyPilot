# OpenAI (required for Live mode — server-side only, no NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (required for sign-in + data persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Your public site URL (no trailing slash)
# Vercel: https://your-app.vercel.app (or your custom domain)
# Local: http://localhost:3000
# Vercel also sets VERCEL_URL automatically — set this explicitly for Stripe/custom domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: attach dynamic community prices to one Product (prod_...)
# STRIPE_PRODUCT_ID=prod_...
# Legacy fixed prices (no longer required — checkout uses P(c)=99*c^0.7):
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# Optional — name shown at top of Stripe Checkout (default: RideBy)
# STRIPE_CHECKOUT_DISPLAY_NAME=RideBy

# Resend (violation emails)
RESEND_FROM_EMAIL=RideBy <notifications@yourdomain.com>
RESEND_API_KEY=re_...
