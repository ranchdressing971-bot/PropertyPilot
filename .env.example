# OpenAI (required for Live mode — server-side only, no NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (required for sign-in + data persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Your public site URL (no trailing slash)
# Vercel: https://your-app.vercel.app (or your custom domain)
# Local: http://localhost:3000
# Vercel also sets VERCEL_URL automatically — set this explicitly for Stripe/custom domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Stripe — Product ID is prod_... but checkout needs the PRICE ID (price_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...   # $149/mo Starter plan
STRIPE_PRICE_PRO=price_...       # $299/mo Professional plan
# Legacy fallback (maps to Starter if STRIPE_PRICE_STARTER is unset):
# STRIPE_PRICE_ID=price_...

# Optional — name shown at top of Stripe Checkout (default: Property Pilot)
# STRIPE_CHECKOUT_DISPLAY_NAME=Property Pilot

# Resend (violation emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Property Pilot <notifications@yourdomain.com>
