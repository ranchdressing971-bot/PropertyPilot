# OpenAI (required for Live mode — server-side only, no NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (required for sign-in + data persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Required for Stripe webhooks to update subscriptions
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# App URL (production — used for Stripe redirects)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Stripe (billing — see docs/YOUR_SETUP_CHECKLIST.md)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Resend (violation emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Property Pilot <notifications@yourdomain.com>

# Optional monitoring
# SENTRY_DSN=https://...
